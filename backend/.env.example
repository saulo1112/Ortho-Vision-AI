# Copy to .env for local overrides. All values have sensible defaults (see app/core/config.py).

# Where the ONNX weights live (relative to the backend working directory).
MODEL_PATH=../model/weights/best.onnx
MODEL_VERSION=orthovision-yolov8s-seg-1.0-onnx

# SQLite in dev; Render injects a postgres:// URL in production.
DATABASE_URL=sqlite:///./orthovision.db

# Inference defaults
CONF_THRESHOLD=0.5
IOU_THRESHOLD=0.7

# Comma-separated origins; "*" is fine for a public demo API.
# CORS_ORIGINS=["*"]
